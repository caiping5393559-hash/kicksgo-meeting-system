PORT=10000
SESSION_SECRET=replace-with-long-random-secret

# Local testing can leave Firebase empty. Render production should set these.
CLOUD_STORAGE_BACKEND=firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_COLLECTION_PREFIX=kicksgo_meeting
FIREBASE_SERVICE_ACCOUNT_B64=base64-encoded-service-account-json

# First-run default accounts. Change these before production.
DEFAULT_ADMIN_PASSWORD=Kicksgo-Admin-2026!
DEFAULT_BOSS_PASSWORD=Kicksgo-Boss-2026!
